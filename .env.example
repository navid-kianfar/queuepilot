# QueuePilot Configuration

# Optional: Set both to enable basic auth for the management UI
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# Encryption key for stored credentials (auto-generated on first run if not set)
# Must be a 64-character hex string (32 bytes)
# ENCRYPTION_KEY=

# Server port (default: 3000)
PORT=3000

# SQLite database path (default: ./queuepilot.db in working directory)
# DATABASE_PATH=/var/lib/queuepilot/data.db
