{
  "name": "queuepilot",
  "version": "1.0.0",
  "private": true,
  "description": "Unified queue management UI for RabbitMQ, Kafka, and BullMQ",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @queuepilot/api dev\" \"pnpm --filter @queuepilot/web dev\"",
    "build": "pnpm --filter @queuepilot/shared build && pnpm --filter @queuepilot/api build && pnpm --filter @queuepilot/web build",
    "start": "pnpm --filter @queuepilot/api start:prod",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer": "^24.40.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@nestjs/core"
    ]
  }
}